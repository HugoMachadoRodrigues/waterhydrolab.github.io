{%- comment -%}
  whl_gallery.liquid — the Field Gallery on the Facilities page, built from
  page.gallery. Each item is one of:
    { file: <video or image> , caption? }   -> auto-detected by extension
    { embed: <YouTube/Vimeo link> , caption? }
  For an embed, the editor just pastes a normal YouTube/Vimeo link (e.g.
  https://youtu.be/ID or https://vimeo.com/ID) — we build the iframe here, so
  no HTML is needed. A pasted <iframe> still works (legacy passthrough).
  Videos loop silently with controls; images are framed to match; embeds
  render in a 16:9 box.
{%- endcomment -%}
{%- assign vids = 'mp4,m4v,webm,ogg,ogv,mov' | split: ',' -%}
{%- if page.gallery and page.gallery.size > 0 -%}
  <div class="whl-video-grid">
    {%- for item in page.gallery -%}
      {%- if item.embed and item.embed != '' -%}
        {%- assign emb = item.embed | strip -%}
        {%- if emb contains '<' -%}
          {%- comment -%} legacy: a pasted embed/iframe code — output as-is {%- endcomment -%}
          <div class="whl-embed">{{ emb }}</div>
        {%- else -%}
          {%- assign src = '' -%}
          {%- if emb contains 'youtube.com/embed/' or emb contains 'player.vimeo.com' -%}
            {%- assign src = emb -%}
          {%- elsif emb contains 'youtu.be/' -%}
            {%- assign yid = emb | split: 'youtu.be/' | last | split: '?' | first | split: '/' | first -%}
            {%- assign src = 'https://www.youtube.com/embed/' | append: yid -%}
          {%- elsif emb contains 'watch?v=' -%}
            {%- assign yid = emb | split: 'watch?v=' | last | split: '&' | first -%}
            {%- assign src = 'https://www.youtube.com/embed/' | append: yid -%}
          {%- elsif emb contains 'vimeo.com/' -%}
            {%- assign vid = emb | split: 'vimeo.com/' | last | split: '?' | first | split: '/' | first -%}
            {%- assign src = 'https://player.vimeo.com/video/' | append: vid -%}
          {%- endif -%}
          {%- if src != '' -%}
            <div class="whl-embed"><iframe src="{{ src }}" title="{{ item.caption | default: 'Embedded video' | escape }}" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe></div>
          {%- endif -%}
        {%- endif -%}
      {%- elsif item.file and item.file != '' -%}
        {%- assign ext = item.file | split: '.' | last | downcase -%}
        {%- if vids contains ext -%}
          <video
            class="whl-video"
            autoplay
            loop
            muted
            playsinline
            controls
            controlslist="nodownload"
            preload="metadata"
            aria-label="{{ item.caption | default: 'Field site footage' | escape }}"
          >
            <source src="{{ item.file | relative_url }}">
          </video>
        {%- else -%}
          <img class="whl-video" src="{{ item.file | relative_url }}" alt="{{ item.caption | default: 'Field site photo' | escape }}" loading="lazy">
        {%- endif -%}
      {%- endif -%}
    {%- endfor -%}
  </div>
{%- endif -%}
